# HashKey Chain testnet
RPC_URL=https://testnet.hsk.xyz

# Deployer private key (hex, with or without 0x prefix — never commit a real key)
PRIVATE_KEY=your_private_key_here

# Testnet USDC.e address on HashKey Chain testnet
STABLE_ADDRESS=0x0000000000000000000000000000000000000000

# Admin address: receives DEFAULT_ADMIN_ROLE and MANAGER_ROLE.
# Defaults to the deployer address if not set.
# ADMIN_ADDRESS=0x0000000000000000000000000000000000000000

# Comma-separated asset addresses (optional — deploy.js reads data/assets.json if absent)
# ASSET_ADDRESSES=0xAddress1,0xAddress2,0xAddress3

# Optional: override if USDC decimals() call fails on-chain
# STABLE_DECIMALS=6

# Optional: your wallet address (informational only)
# PUBLIC_ADDRESS=0x0000000000000000000000000000000000000000